generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VOLUNTEER
  ADMIN
}

enum NotificationType {
  CRISIS_ALERT
  CRISIS_UPDATE
  NGO_REPORT_PROMPT
  RESERVATION_REQUEST
  RESERVATION_APPROVED
  RESERVATION_DECLINED
  DISPATCH_ALERT
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  PUBLISHED
  UNDER_REVIEW
}

enum IncidentType {
  FLOOD
  FIRE
  EARTHQUAKE
  BUILDING_COLLAPSE
  ROAD_ACCIDENT
  VIOLENCE
  MEDICAL_EMERGENCY
  OTHER
}

enum InteractionContext {
  RESCUE_OPERATION
  MEDICAL_AID
  SUPPLY_DISTRIBUTION
  SHELTER_MANAGEMENT
  OTHER
}

enum TaskCategory {
  RESCUE
  MEDICAL_AID
  SUPPLY_DISTRIBUTION
  SHELTER_SETUP
  CLEANUP
  COUNSELING
  TRANSPORTATION
  OTHER
}

enum TaskStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BadgeType {
  FIRST_RESPONDER
  RISING_STAR
  CRISIS_HERO
  COMMUNITY_GUARDIAN
  ELITE_VOLUNTEER
  CENTURY
  TEAM_PLAYER
}

enum CrisisResponderStatus {
  RESPONDING
  EN_ROUTE
  ON_SITE
  COMPLETED
  UNAVAILABLE
}

enum DispatchAlertStatus {
  QUEUED
  SENT
  FAILED
}

model User {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName             String
  email                String    @unique
  phone                String    @unique
  passwordHash         String
  location             String
  latitude             Float?
  longitude            Float?
  role                 Role      @default(USER)
  avatarUrl            String?
  skills               String[]
  availability         String?
  certifications       String?
  dispatchOptIn        Boolean   @default(false)
  isBanned             Boolean   @default(false)
  isFlagged            Boolean   @default(false)
  volunteerFlagReasons String[]
  resetTokenHash       String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Feature 3.7: Gamification
  totalPoints          Int       @default(0)
  totalVerifiedHours   Float     @default(0)

  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  folders         SecureFolder[] // Feature 4: Secure Documentation
  evidencePosts   EvidencePost[]
  comments        Comment[]
  likes           Like[]
  evidenceFlags   EvidenceFlag[]
  crisisUpdates   CrisisEventUpdate[]
  notificationSub NotificationSubscription?
  notifications   Notification[]
  reservations    Reservation[]
  volunteerTasks  VolunteerTask[]
  badges          Badge[]
  dispatchAlertLogs DispatchAlertLog[]
  crisisResponses   CrisisResponder[]

  @@index([role, isBanned])
  @@index([role, isFlagged])
}

model IncidentReport {
  id                      String           @id @default(auto()) @map("_id") @db.ObjectId
  reporterId              String           @db.ObjectId
  incidentTitle           String
  description             String
  incidentType            IncidentType
  locationText            String
  latitude                Float?
  longitude               Float?
  mediaFilenames          String[]
  sourceAudioFilename     String?
  detectedLanguage        String?
  languageProbability     Float?
  translatedDescription   String?
  credibilityScore        Int
  severityLevel           IncidentSeverity
  classifiedIncidentType  IncidentType
  classifiedIncidentTitle String
  spamFlagged             Boolean          @default(false)
  status                  IncidentStatus   @default(PUBLISHED)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  crisisEvents CrisisEventReport[]

  @@index([reporterId, createdAt(sort: Desc)])
  @@index([status, severityLevel])
}

model Review {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  reviewerId         String             @db.ObjectId
  volunteerId        String             @db.ObjectId
  rating             Int
  text               String
  interactionContext InteractionContext @default(OTHER)
  interactionDate    DateTime
  wouldWorkAgain     Boolean
  crisisEventId      String             @db.ObjectId
  isFlagged          Boolean            @default(false)
  flagReasons        String[]
  createdAt          DateTime           @default(now())

  reviewer    User       @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  volunteer   User       @relation("ReviewsReceived", fields: [volunteerId], references: [id])
  crisisEvent CrisisEvent @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)

  @@index([volunteerId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
  @@index([reviewerId, volunteerId, crisisEventId])
  @@index([isFlagged])
}

model Resource {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  category          String
  quantity          Int
  originalQuantity  Int?
  unit              String
  condition         String
  address           String
  latitude          Float
  longitude         Float
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  contactPreference String
  photos            String[]
  notes             String?
  status            String    @default("Available")
  userId            String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  histories    ResourceHistory[]
  reservations Reservation[]
  @@index([latitude, longitude])
}

// Feature 4: Secure Documentation
model SecureFolder {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  crisisId    String?      @db.ObjectId // Optional link to a crisis event
  ownerId     String       @db.ObjectId
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files       FolderFile[]
  notes       FolderNote[]
  shareLinks  ShareLink[]

  isDeleted Boolean   @default(false)
  isPinned  Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model FolderFile {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId   String       @db.ObjectId
  folder     SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploaderId String       @db.ObjectId // To track who uploaded it

  fileName    String // The original name of the file
  description String? // Optional description/caption
  fileUrl     String // URL from your storage provider (e.g., AWS S3)
  fileType    String // e.g., 'image/jpeg', 'video/mp4'
  sizeBytes   Int
  gpsLat      Float?
  gpsLng      Float?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

model FolderNote {
  id       String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId String       @db.ObjectId
  folder   SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  authorId String       @db.ObjectId

  content String
  gpsLat  Float?
  gpsLng  Float?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ShareLink {
  id       String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId String       @db.ObjectId
  folder   SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  token     String    @unique
  expiresAt DateTime?
  isRevoked Boolean   @default(false)

  createdAt DateTime @default(now())
}

enum CrisisEventStatus {
  REPORTED
  VERIFIED
  UNDER_INVESTIGATION
  RESPONSE_IN_PROGRESS
  CONTAINED
  RESOLVED
  CLOSED
}

enum CrisisUpdateType {
  STATUS_CHANGE
  FIELD_OBSERVATION
  ACCESS_UPDATE
  IMPACT_UPDATE
  RESOURCE_NEED
  CLOSURE_NOTE
  ADMIN_CORRECTION
  RESPONDER_STATUS
}

enum CrisisUpdateVerificationStatus {
  RESPONDER_CONFIRMED
  ADMIN_CONFIRMED
  SYSTEM_LOGGED
}

enum CrisisAccessStatus {
  OPEN
  LIMITED
  BLOCKED
  UNKNOWN
}

model CrisisEvent {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  incidentType  IncidentType
  severityLevel IncidentSeverity
  locationText  String
  latitude      Float?
  longitude     Float?
  status        CrisisEventStatus @default(REPORTED)
  sitRepText    String?
  reportCount   Int               @default(0)
  reporterCount Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reports CrisisEventReport[]
  updates CrisisEventUpdate[]
  reviews Review[]
  responders CrisisResponder[]
  dispatchAlertLogs DispatchAlertLog[]

  @@index([status, severityLevel, createdAt(sort: Desc)])
  @@index([latitude, longitude])
}

model CrisisEventReport {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  crisisEventId    String   @db.ObjectId
  incidentReportId String   @db.ObjectId
  createdAt        DateTime @default(now())

  crisisEvent    CrisisEvent    @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
  incidentReport IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)

  @@unique([crisisEventId, incidentReportId])
  @@index([incidentReportId])
  @@index([crisisEventId])
}

model CrisisResponder {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  crisisEventId String               @db.ObjectId
  volunteerId   String               @db.ObjectId
  status        CrisisResponderStatus @default(RESPONDING)
  optedInAt     DateTime             @default(now())
  lastStatusAt  DateTime             @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  crisisEvent CrisisEvent @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
  volunteer  User        @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([crisisEventId, volunteerId])
  @@index([crisisEventId, status, updatedAt(sort: Desc)])
  @@index([volunteerId, status, updatedAt(sort: Desc)])
}

model EvidencePost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String
  location    String
  latitude    Float?
  longitude   Float?
  mediaUrls   String[] // Local filenames or URLs
  mediaType   String // 'IMAGE' or 'VIDEO'
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments Comment[]
  likes    Like[]
  flags    EvidenceFlag[]

  @@index([userId, createdAt(sort: Desc)])
}

model ResourceHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  resourceId   String   @db.ObjectId
  oldStatus    String
  newStatus    String
  oldQuantity  Int
  newQuantity  Int
  createdAt    DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model Reservation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  resourceId  String   @db.ObjectId
  quantity    Int
  status      String   // Pending | Approved | Declined | Expired
  justification String
  pickupTime  DateTime?
  decisionReason String?
  createdAt   DateTime @default(now())
  
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model EvidenceFlag {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  reason    String
  createdAt DateTime     @default(now())

  @@index([postId])
}

model Comment {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([postId, createdAt(sort: Desc)])
}

model Like {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
}

model CrisisEventUpdate {
  id                     String                          @id @default(auto()) @map("_id") @db.ObjectId
  crisisEventId          String                          @db.ObjectId
  crisisEvent            CrisisEvent                     @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
  updaterId              String                          @db.ObjectId
  updater                User                            @relation(fields: [updaterId], references: [id])
  previousStatus         CrisisEventStatus
  newStatus              CrisisEventStatus
  updateNote             String
  updateType             CrisisUpdateType?
  verificationStatus     CrisisUpdateVerificationStatus?
  newSeverity            IncidentSeverity?
  affectedArea           String?
  accessStatus           CrisisAccessStatus?
  casualtyCount          Int?
  displacedCount         Int?
  damageNotes            String?
  resourceNeedsText      String?
  closureAreaSafe        Boolean?
  closurePeopleAccounted Boolean?
  closureNeedsStabilized Boolean?
  isFlagged              Boolean                         @default(false)
  dismissedById          String?                         @db.ObjectId
  dismissedAt            DateTime?
  createdAt              DateTime                        @default(now())

  @@index([crisisEventId, createdAt(sort: Desc)])
}

model NotificationSubscription {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @db.ObjectId
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  incidentTypes   IncidentType[]
  radiusKm        Float             @default(10)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId])
  @@index([userId, isActive])
}

model Notification {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @db.ObjectId
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  crisisEventId   String?           @db.ObjectId
  title           String
  body            String
  survivalInstruction String?
  isRead          Boolean           @default(false)
  createdAt       DateTime          @default(now())
  reservationId String? @db.ObjectId
  type NotificationType?
  statusSnapshot  String?  // "REQUESTED | APPROVED | DECLINED"

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ── Feature 3.7: Volunteer Timesheet & Gamification ─────────────────────────

model VolunteerTask {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  volunteerId     String       @db.ObjectId
  volunteer       User         @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  title           String
  description     String
  category        TaskCategory
  hoursSpent      Float
  dateOfTask      DateTime
  crisisEventId   String?      @db.ObjectId
  status          TaskStatus   @default(PENDING)
  pointsAwarded   Int          @default(0)
  evidenceUrls    String[]
  verifiedById    String?      @db.ObjectId
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([volunteerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([crisisEventId])
}

model Badge {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType   BadgeType
  awardedAt   DateTime  @default(now())

  @@unique([userId, badgeType])
  @@index([userId])
}

// ── Feature 3.3: Volunteer Crisis Opt-In & Dispatch Email Alerts ────────────

model DispatchAlertLog {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  userId            String            @db.ObjectId
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  crisisEventId     String?           @db.ObjectId
  crisisEvent       CrisisEvent?      @relation(fields: [crisisEventId], references: [id])
  emailMasked       String
  status            DispatchAlertStatus
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime          @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([crisisEventId, createdAt(sort: Desc)])
}
