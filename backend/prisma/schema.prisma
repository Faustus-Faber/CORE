generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VOLUNTEER
  ADMIN
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  PUBLISHED
  UNDER_REVIEW
}

enum IncidentType {
  FLOOD
  FIRE
  EARTHQUAKE
  BUILDING_COLLAPSE
  ROAD_ACCIDENT
  VIOLENCE
  MEDICAL_EMERGENCY
  OTHER
}

enum InteractionContext {
  RESCUE_OPERATION
  MEDICAL_AID
  SUPPLY_DISTRIBUTION
  SHELTER_MANAGEMENT
  OTHER
}

model User {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName             String
  email                String    @unique
  phone                String    @unique
  passwordHash         String
  location             String
  latitude             Float?
  longitude            Float?
  role                 Role      @default(USER)
  avatarUrl            String?
  skills               String[]
  availability         String?
  certifications       String?
  dispatchOptIn        Boolean   @default(false)
  isBanned             Boolean   @default(false)
  isFlagged            Boolean   @default(false)
  volunteerFlagReasons String[]
  resetTokenHash       String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  folders         SecureFolder[] // Feature 4: Secure Documentation
  evidencePosts   EvidencePost[]
  comments        Comment[]
  likes           Like[]
  evidenceFlags   EvidenceFlag[]
  crisisUpdates   CrisisEventUpdate[]
  notificationSub NotificationSubscription?
  notifications   Notification[]

  @@index([role, isBanned])
  @@index([role, isFlagged])
}

model IncidentReport {
  id                      String           @id @default(auto()) @map("_id") @db.ObjectId
  reporterId              String           @db.ObjectId
  incidentTitle           String
  description             String
  incidentType            IncidentType
  locationText            String
  latitude                Float?
  longitude               Float?
  mediaFilenames          String[]
  sourceAudioFilename     String?
  detectedLanguage        String?
  languageProbability     Float?
  translatedDescription   String?
  credibilityScore        Int
  severityLevel           IncidentSeverity
  classifiedIncidentType  IncidentType
  classifiedIncidentTitle String
  spamFlagged             Boolean          @default(false)
  status                  IncidentStatus   @default(PUBLISHED)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  crisisEvents CrisisEventReport[]

  @@index([reporterId, createdAt(sort: Desc)])
  @@index([status, severityLevel])
}

model Review {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  reviewerId         String             @db.ObjectId
  volunteerId        String             @db.ObjectId
  rating             Int
  text               String
  interactionContext InteractionContext @default(OTHER)
  interactionDate    DateTime
  wouldWorkAgain     Boolean
  crisisEventId      String?
  isFlagged          Boolean            @default(false)
  flagReasons        String[]
  createdAt          DateTime           @default(now())

  reviewer  User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  volunteer User @relation("ReviewsReceived", fields: [volunteerId], references: [id])

  @@index([volunteerId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
  @@index([isFlagged])
}

model Resource {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  category          String
  quantity          Int
  unit              String
  condition         String
  address           String
  latitude          Float
  longitude         Float
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  contactPreference String
  photos            String[]
  notes             String?
  status            String    @default("Available")
  userId            String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  histories    ResourceHistory[]
  reservations Reservation[]
  @@index([latitude, longitude])
}

// Feature 4: Secure Documentation
model SecureFolder {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  crisisId    String?      @db.ObjectId // Optional link to a crisis event
  ownerId     String       @db.ObjectId
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files       FolderFile[]
  notes       FolderNote[]
  shareLinks  ShareLink[]

  isDeleted Boolean   @default(false)
  isPinned  Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model FolderFile {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId   String       @db.ObjectId
  folder     SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploaderId String       @db.ObjectId // To track who uploaded it

  fileName    String // The original name of the file
  description String? // Optional description/caption
  fileUrl     String // URL from your storage provider (e.g., AWS S3)
  fileType    String // e.g., 'image/jpeg', 'video/mp4'
  sizeBytes   Int
  gpsLat      Float?
  gpsLng      Float?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

model FolderNote {
  id       String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId String       @db.ObjectId
  folder   SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  authorId String       @db.ObjectId

  content String
  gpsLat  Float?
  gpsLng  Float?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ShareLink {
  id       String       @id @default(auto()) @map("_id") @db.ObjectId
  folderId String       @db.ObjectId
  folder   SecureFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  token     String    @unique
  expiresAt DateTime?
  isRevoked Boolean   @default(false)

  createdAt DateTime @default(now())
}

enum CrisisEventStatus {
  REPORTED
  VERIFIED
  UNDER_INVESTIGATION
  RESPONSE_IN_PROGRESS
  CONTAINED
  RESOLVED
  CLOSED
}

model CrisisEvent {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  incidentType  IncidentType
  severityLevel IncidentSeverity
  locationText  String
  latitude      Float?
  longitude     Float?
  status        CrisisEventStatus @default(REPORTED)
  sitRepText    String?
  reportCount   Int               @default(0)
  reporterCount Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reports CrisisEventReport[]
  updates CrisisEventUpdate[]

  @@index([status, severityLevel, createdAt(sort: Desc)])
  @@index([latitude, longitude])
}

model CrisisEventReport {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  crisisEventId    String   @db.ObjectId
  incidentReportId String   @db.ObjectId
  createdAt        DateTime @default(now())

  crisisEvent    CrisisEvent    @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
  incidentReport IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)

  @@unique([crisisEventId, incidentReportId])
  @@index([incidentReportId])
  @@index([crisisEventId])
}

model EvidencePost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String
  location    String
  latitude    Float?
  longitude   Float?
  mediaUrls   String[] // Local filenames or URLs
  mediaType   String // 'IMAGE' or 'VIDEO'
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments Comment[]
  likes    Like[]
  flags    EvidenceFlag[]

  @@index([userId, createdAt(sort: Desc)])
}

model ResourceHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  resourceId   String   @db.ObjectId
  oldStatus    String
  newStatus    String
  oldQuantity  Int
  newQuantity  Int
  createdAt    DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model Reservation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  resourceId  String   @db.ObjectId
  quantity    Int
  status      String   // Pending | Approved | Declined | Expired
  justification String
  pickupTime  DateTime?
  createdAt   DateTime @default(now())
  
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model EvidenceFlag {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  reason    String
  createdAt DateTime     @default(now())

  @@index([postId])
}

model Comment {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([postId, createdAt(sort: Desc)])
}

model Like {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  postId    String       @db.ObjectId
  post      EvidencePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
}

model CrisisEventUpdate {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  crisisEventId   String            @db.ObjectId
  crisisEvent     CrisisEvent       @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
  updaterId       String            @db.ObjectId
  updater         User              @relation(fields: [updaterId], references: [id])
  previousStatus  CrisisEventStatus
  newStatus       CrisisEventStatus
  updateNote      String
  newSeverity     IncidentSeverity?
  affectedArea    String?
  casualtyCount   Int?
  displacedCount  Int?
  damageNotes     String?
  isFlagged       Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@index([crisisEventId, createdAt(sort: Desc)])
}

model NotificationSubscription {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @db.ObjectId
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  incidentTypes   IncidentType[]
  radiusKm        Float             @default(10)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId])
  @@index([userId, isActive])
}

model Notification {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @db.ObjectId
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  crisisEventId   String?           @db.ObjectId
  title           String
  body            String
  survivalInstruction String?
  isRead          Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}
