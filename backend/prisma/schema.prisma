generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VOLUNTEER
  ADMIN
}

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName          String
  email             String   @unique
  phone             String   @unique
  passwordHash      String
  location          String
  role              Role     @default(USER)
  avatarUrl         String?
  skills            String[]
  availability      String?
  certifications    String?
  dispatchOptIn     Boolean  @default(false)
  isBanned          Boolean  @default(false)
  resetTokenHash    String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Resource {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  category          String
  quantity          Int
  unit              String
  condition         String
  address           String
  latitude          Float
  longitude         Float
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  contactPreference String
  photos            String[] // store image URLs or base64 paths
  notes             String?
  status            String   @default("Available")
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([latitude, longitude]) // for geo queries
}